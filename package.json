{
  "name": "portfolia",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "test": "npm run test --workspace=server",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.6.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true
  }
}
